<Window x:Class="QuickDoc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuickDoc"
        mc:Ignorable="d"
        Icon="pack://siteoforigin:,,,/Images/PentairLogoNoTitle.png"
        Title="QuickDoc" Height="650" Width="500">
    <Grid>
        <!-- Shows view based on the NavigationStore's currentView -->
        <ContentControl Content="{Binding NavigationStore.CurrentView}"/>
    </Grid>
</Window>
