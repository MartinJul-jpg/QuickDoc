<UserControl x:Class="QuickDoc.Styles.NodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuickDoc.Styles"
             xmlns:viewmodel="clr-namespace:QuickDoc.ViewModel"
             mc:Ignorable="d" 
             Background="White"
             d:DesignHeight="650" d:DesignWidth="400">

    <!-- Defines  -->
    <UserControl.Resources>

        <!-- Section attribute template -->
        <DataTemplate DataType="{x:Type viewmodel:SectionViewModel}">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Section: " FontSize="16"/>
                    <TextBlock Text="{Binding SectionNumber}" FontSize="16" />
                </StackPanel>
                <TextBlock Text="{Binding Title}" FontSize="14" Margin="5,0,0,0"/>
            </StackPanel>
        </DataTemplate>

        <!-- Unit attribute template -->
        <DataTemplate DataType="{x:Type viewmodel:UnitViewModel}">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Unit: " FontSize="16"/>
                    <TextBlock Text="{Binding UnitNumber}" FontSize="16" />
                </StackPanel>
                <TextBlock Text="{Binding Description}" FontSize="14" Margin="5,0,0,0"/>
            </StackPanel>
        </DataTemplate>

        <!-- Tag attribute template -->
        <DataTemplate DataType="{x:Type viewmodel:TagViewModel}">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Tag: " FontSize="16"/>
                    <TextBlock Text="{Binding TagNumber}" FontSize="16" />
                </StackPanel>
                <TextBlock Text="{Binding Description}" FontSize="14" Margin="5,0,0,0"/>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.ColumnSpan="2">
                        <StackPanel x:Name="NodeAttributeChildFirstRow" Orientation="Horizontal" Grid.ColumnSpan="2">
                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="0">
                                <TextBlock Text="Line number: "/>
                                <TextBlock Text="{Binding LineNumber}" TextWrapping="Wrap" Width="80" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1">
                                <TextBlock Text="Haffman Tag: "/>
                                <TextBlock Text="{Binding HaffmanTag}" TextWrapping="Wrap" Width="80" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="NodeAttributeChildSecoundRow" Orientation="Horizontal" Grid.ColumnSpan="2">
                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="0">
                                <TextBlock Text="Belongs to: "/>
                                <TextBlock Text="{Binding BelongsTo}" TextWrapping="Wrap" Width="80" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1">
                                <TextBlock Text="Vendor Tag: "/>
                                <TextBlock Text="{Binding VendorTag}" TextWrapping="Wrap" Width="80" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="NodeAttributeChildThridRow" Orientation="Horizontal" Grid.ColumnSpan="2">
                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="0">
                                <TextBlock Text="Union Tag number: "/>
                                <TextBlock Text="{Binding UnionTagNumber}" TextWrapping="Wrap" Width="80" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1">
                                <TextBlock Text="Customer Tag: "/>
                                <TextBlock Text="{Binding CustomerTag}" TextWrapping="Wrap" Width="80" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- Item attribute template -->
        <DataTemplate DataType="{x:Type viewmodel:ItemViewModel}">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Item: " FontSize="16"/>
                    <TextBlock Text="{Binding ItemNumber}" FontSize="16" />
                </StackPanel>
                <TextBlock Text="{Binding Description}" FontSize="14" Margin="5,0,0,0"/>
            </StackPanel>
        </DataTemplate>

        <!-- Project attribute template -->
        <DataTemplate DataType="{x:Type viewmodel:ProjectViewModel}">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Project: " FontSize="16"/>
                    <TextBlock Text="{Binding ProjectNumber}" FontSize="16" />
                </StackPanel>
                <TextBlock Text="{Binding Description}" FontSize="14" Margin="5,0,0,0"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="7*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="PentairLogo" Grid.Row="0" Background="#014e99">
            <Image Margin="260,5,5,3" Source="pack://siteoforigin:,,,/Images/Pentair_Schroff_Logo.png"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>
            
            <!-- Child items listbox -->
            <Border Grid.Row="1" BorderBrush="#014e99" BorderThickness="2" Margin="20">
                <ListBox Grid.Row="1" d:ItemsSource="{d:SampleData ItemCount=5}"/>
            </Border>

            <!-- Documents listbox -->
            <Border Grid.Row="2" BorderBrush="#014e99" BorderThickness="2" Margin="20">
                <ListBox Grid.Row="2" ItemsSource="{Binding Documents}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Label Content="{Binding Description}" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border BorderBrush="#014e99" BorderThickness="2" Margin="20,20,20,20">
                <ContentControl>
                    <ContentControl.Content>
                        <PriorityBinding>
                            <Binding Path="CurrentNode"/>
                        </PriorityBinding>
                    </ContentControl.Content>
                </ContentControl>
            </Border>

        </Grid>
    </Grid>
</UserControl>
