<UserControl x:Class="QuickDoc.View.NodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuickDoc.View"
             xmlns:viewmodel="clr-namespace:QuickDoc.ViewModel"
             mc:Ignorable="d" 
             Background="White"
             d:DesignHeight="650" d:DesignWidth="400">

    <!-- Defines  -->
    <UserControl.Resources>
        <!-- Section attribute template -->
        <DataTemplate DataType="{x:Type viewmodel:SectionViewModel}">
            <StackPanel>
                <Border BorderBrush="#014e99" BorderThickness="2" Margin="20">
                    <StackPanel Margin="10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Section: " FontSize="16"/>
                            <TextBlock Text="{Binding SectionNumber}" FontSize="16" />
                        </StackPanel>
                        <TextBlock Text="{Binding Title}" FontSize="14" Margin="5,0,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" BorderBrush="#014e99" BorderThickness="2" Margin="20">
                    <StackPanel Margin="10">
                        <TextBlock Text="Tags: " FontSize="16" Margin="0,0,0,5"/>
                        <ListBox ItemsSource="{Binding DataContext.Children, RelativeSource={RelativeSource AncestorType=local:NodeView}}"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Background="BlueViolet" Command="{Binding DataContext.GOINTO, RelativeSource={RelativeSource AncestorType=local:NodeView}}" CommandParameter="{Binding}">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="Button.HoverBackground" Color="#FF9BC9F5" />
                                            <SolidColorBrush x:Key="Button.PressedBackground" Color="#FF2F6FAE" />
                                            <SolidColorBrush x:Key="Button.DefaultBackground" Color="#FF538CC5"/>
                                        </Button.Resources>
                                        <TextBlock Text="{Binding}" FontWeight="DemiBold" Margin="5"/>
                                    </Button>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>

        <!-- Unit attribute template -->
        <DataTemplate DataType="{x:Type viewmodel:UnitViewModel}">
            <StackPanel>
                <Border BorderBrush="#014e99" BorderThickness="2" Margin="20">
                    <StackPanel Margin="10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Unit: " FontSize="16"/>
                            <TextBlock Text="{Binding UnitNumber}" FontSize="16" />
                        </StackPanel>
                        <TextBlock Text="{Binding Description}" FontSize="14" Margin="5,0,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" BorderBrush="#014e99" BorderThickness="2" Margin="20">
                    <StackPanel Margin="10">
                        <TextBlock Text="Sections: " FontSize="16" Margin="0,0,0,5"/>
                        <ListBox ItemsSource="{Binding DataContext.Children, RelativeSource={RelativeSource AncestorType=local:NodeView}}"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Background="BlueViolet" Command="{Binding DataContext.GOINTO, RelativeSource={RelativeSource AncestorType=local:NodeView}}" CommandParameter="{Binding}">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="Button.HoverBackground" Color="#FF9BC9F5" />
                                            <SolidColorBrush x:Key="Button.PressedBackground" Color="#FF2F6FAE" />
                                            <SolidColorBrush x:Key="Button.DefaultBackground" Color="#FF538CC5"/>
                                        </Button.Resources>
                                        <TextBlock Text="{Binding}" FontWeight="DemiBold" Margin="5"/>
                                    </Button>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>

        <!-- Tag attribute template -->
        <DataTemplate DataType="{x:Type viewmodel:TagViewModel}">
            <StackPanel>
                <Border BorderBrush="#014e99" BorderThickness="2" Margin="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="10">
                            <TextBlock Text="Tag: " FontSize="16"/>
                            <TextBlock Text="{Binding TagNumber}" FontSize="16" />
                        </StackPanel>
                        <TextBlock Text="{Binding Description}" FontSize="14" Margin="10,0,10,5"/>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="0">
                                <TextBlock Text="Line number: " Width="130"/>
                                <TextBlock Text="{Binding LineNumber}" TextWrapping="Wrap" Width="200" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1">
                                <TextBlock Text="Haffman Tag: " Width="130"/>
                                <TextBlock Text="{Binding HaffmanTag}" TextWrapping="Wrap" Width="200"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="0">
                                <TextBlock Text="Belongs to: " Width="130"/>
                                <TextBlock Text="{Binding BelongsTo}" TextWrapping="Wrap" Width="200" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1">
                                <TextBlock Text="Vendor Tag: " Width="130"/>
                                <TextBlock Text="{Binding VendorTag}" TextWrapping="Wrap" Width="200" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="0">
                                <TextBlock Text="Union Tag number: " Width="130"/>
                                <TextBlock Text="{Binding UnionTagNumber}" TextWrapping="Wrap" Width="200" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5,5,5,10" Grid.Column="1">
                                <TextBlock Text="Customer Tag: " Width="130"/>
                                <TextBlock Text="{Binding CustomerTag}" TextWrapping="Wrap" Width="200" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" BorderBrush="#014e99" BorderThickness="2" Margin="20">
                    <StackPanel Margin="10">
                        <TextBlock Text="Items: " FontSize="16" Margin="0,0,0,5"/>
                        <ListBox Name="ChildListBox" ItemsSource="{Binding DataContext.Children, RelativeSource={RelativeSource AncestorType=local:NodeView}}"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="2" BorderBrush="DarkSlateBlue" Width="280">
                                        <StackPanel Margin="5">
                                            <Button Background="#FF3D8AD5" Command="{Binding DataContext.GOINTO, RelativeSource={RelativeSource AncestorType=local:NodeView}}" CommandParameter="{Binding}">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="Button.HoverBackground" Color="#FF9BC9F5" />
                                                    <SolidColorBrush x:Key="Button.PressedBackground" Color="#FF2F6FAE" />
                                                    <SolidColorBrush x:Key="Button.DefaultBackground" Color="#FF538CC5"/>
                                                </Button.Resources>
                                                <TextBlock Text="{Binding}" Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            </Button>
                                            <Button Background="BlueViolet" Margin="5">
                                                <TextBlock Text="✍" FontWeight="DemiBold" Margin="5"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>

        <!-- Item attribute template -->
        <DataTemplate DataType="{x:Type viewmodel:ItemViewModel}">
            <Border Grid.Row="1" BorderBrush="#014e99" BorderThickness="2" Margin="20">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Item: " FontSize="16"/>
                        <TextBlock Text="{Binding ItemNumber}" FontSize="16" />
                    </StackPanel>
                    <TextBlock Text="{Binding Description}" FontSize="14" Margin="5,0,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Project attribute template -->
        <DataTemplate DataType="{x:Type viewmodel:ProjectViewModel}">
            <StackPanel>
                <Border BorderBrush="#014e99" BorderThickness="2" Margin="20">
                    <StackPanel Margin="10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Project: " FontSize="16"/>
                            <TextBlock Text="{Binding ProjectNumber}" FontSize="16" />
                        </StackPanel>
                        <TextBlock Text="{Binding Description}" FontSize="14" Margin="5,0,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" BorderBrush="#014e99" BorderThickness="2" Margin="20">
                    <StackPanel Margin="10">
                        <TextBlock Text="Units: " FontSize="16" Margin="0,0,0,5"/>
                        <ListBox ItemsSource="{Binding DataContext.Children, RelativeSource={RelativeSource AncestorType=local:NodeView}}"
                                 HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Background="#FF3D8AD5" Command="{Binding DataContext.GOINTO, RelativeSource={RelativeSource AncestorType=local:NodeView}}" CommandParameter="{Binding}">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="Button.HoverBackground" Color="#FF9BC9F5" />
                                            <SolidColorBrush x:Key="Button.PressedBackground" Color="#FF2F6FAE" />
                                            <SolidColorBrush x:Key="Button.DefaultBackground" Color="#FF538CC5"/>
                                        </Button.Resources>
                                        <TextBlock Text="{Binding}" Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    </Button>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>



    <!-- Window -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="7*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="PentairLogo" Grid.Row="0" Background="#014e99">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="2" Margin="0,20,20,20" Source="pack://siteoforigin:,,,/Images/Pentair_Schroff_Logo.png" HorizontalAlignment="Right" Height="35"/>
            <Button Content="↩"
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    Margin="20"
                    VerticalAlignment="Center"
                    Width="40"
                    Height="40"
                    Background="#FF538CC5"
                    Foreground="Black"
                    Command="{Binding GOBACK}"
                    CommandParameter="{Binding}">
                <Button.Resources>
                    <SolidColorBrush x:Key="Button.HoverBackground" Color="#FF9BC9F5" />
                    <SolidColorBrush x:Key="Button.PressedBackground" Color="#FF2F6FAE" />
                    <SolidColorBrush x:Key="Button.DefaultBackground" Color="#FF538CC5"/>
                </Button.Resources>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer>
                <StackPanel>
                    <!-- Attribute and child items list -->
                    <ContentControl>
                        <ContentControl.Content>
                            <PriorityBinding>
                                <Binding Path="CurrentNode"/>
                            </PriorityBinding>
                        </ContentControl.Content>
                    </ContentControl>

                    <!-- Documents listbox -->
                    <Border Grid.Row="2" BorderBrush="#014e99" BorderThickness="2" Margin="20">
                        <StackPanel Margin="10">
                            <TextBlock Text="Documents:" FontSize="16"/>
                            <ListBox Grid.Row="2" ItemsSource="{Binding Documents}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Label Content="{Binding Description}" FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
