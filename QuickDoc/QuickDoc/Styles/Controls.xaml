<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base style you can reuse explicitly -->
    <Style x:Key="ButtonDefault" TargetType="{x:Type Button}">
        <Style.Resources>
            <!-- default colors (can be overridden per Button) -->
            <SolidColorBrush x:Key="Button.NotEnableBackground" Color="LightGray"/>
            <SolidColorBrush x:Key="Button.DefaultBackground" Color="#5cbb4e"/>
            <SolidColorBrush x:Key="Button.HoverBackground" Color="#FF70CF62" />
            <SolidColorBrush x:Key="Button.PressedBackground" Color="#FF48A73A" />
        </Style.Resources>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="bdr"
                            CornerRadius="10"
                            Margin="3"
                            BorderThickness="1"
                            BorderBrush="Black"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          TextBlock.FontFamily="Calibri"
                                          ContentSource="Content"
                                          TextBlock.FontSize="16" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="False">
                            <Setter TargetName="bdr"
                                    Property="Background"
                                    Value="{DynamicResource Button.DefaultBackground}"/>
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bdr"
                                    Property="Background"
                                    Value="{DynamicResource Button.HoverBackground}" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bdr"
                                    Property="Background"
                                    Value="{DynamicResource Button.PressedBackground}" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bdr"
                                    Property="Background"
                                    Value="{DynamicResource Button.NotEnableBackground}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Makes it the default for ALL Buttons -->
    <Style TargetType="{x:Type Button}" BasedOn="{StaticResource ButtonDefault}" />

</ResourceDictionary>