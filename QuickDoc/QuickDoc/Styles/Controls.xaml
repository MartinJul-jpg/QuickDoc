<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Style of button -->
    <Style TargetType="{x:Type Button}">
        <!-- Template for button style -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <!-- Content handles within a border -->
                    <Border x:Name="bdr" CornerRadius="10" Margin="3" BorderThickness="1" BorderBrush="Black" Background="#5cbb4e">
                        <!-- ContentPresenter properties. Set the content source as the content from each control define below -->
                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" TextBlock.FontFamily="Calibri" ContentSource="Content" TextBlock.FontSize="16" />
                    </Border>
                    <!-- Required triggers define here -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bdr" Property="Background" Value="#FF70CF62"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bdr" Property="Background" Value="#7FD9D9D9"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bdr" Property="Background" Value="#FF48A73A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Style of border -->
    
    <!-- Style of listbox -->
    
    <!-- Style of textbox -->
    
</ResourceDictionary>