<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Style for button -->
    <Style x:Key="ButtonDefault" TargetType="{x:Type Button}">
        <Style.Resources>
            <!-- default colors (can be overridden per Button) -->
            <SolidColorBrush x:Key="Button.NotEnableBackground" Color="LightGray"/>
            <SolidColorBrush x:Key="Button.DefaultBackground" Color="#5cbb4e"/>
            <SolidColorBrush x:Key="Button.HoverBackground" Color="#FF70CF62" />
            <SolidColorBrush x:Key="Button.PressedBackground" Color="#FF48A73A" />
        </Style.Resources>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="bdr"
                            CornerRadius="10"
                            Margin="3"
                            BorderThickness="1"
                            BorderBrush="Black"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          TextBlock.FontFamily="Calibri"
                                          ContentSource="Content"
                                          TextBlock.FontSize="16" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="False">
                            <Setter TargetName="bdr"
                                    Property="Background"
                                    Value="{DynamicResource Button.DefaultBackground}"/>
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bdr"
                                    Property="Background"
                                    Value="{DynamicResource Button.HoverBackground}" />
                            <Setter Property="Cursor" Value="Hand" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bdr"
                                    Property="Background"
                                    Value="{DynamicResource Button.PressedBackground}" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bdr"
                                    Property="Background"
                                    Value="{DynamicResource Button.NotEnableBackground}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Makes it the default for ALL Buttons -->
    <Style TargetType="{x:Type Button}" BasedOn="{StaticResource ButtonDefault}" />


    <!-- Style for Border -->
    <Style x:Key="BorderDefault" TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="#014e99"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <!-- Makes it the default for ALL Borders -->
    <Style TargetType="{x:Type Border}" BasedOn="{StaticResource BorderDefault}" />

    <!-- Style for TextBox -->
    <Style x:Key="DefaultTextbox" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="Black"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="3,1,1,1"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border CornerRadius="10"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            Height="30">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      FontSize="12" FontFamily="Comic Sans MS" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Makes it the default for ALL TextBoxes -->
    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource DefaultTextbox}" />
</ResourceDictionary>